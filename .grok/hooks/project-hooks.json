{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/session-start.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/detect-feedback.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|run_terminal_command",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/block-pkill.ps1\"",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/pre-commit-check.ps1\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|search_replace",
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/mark-review.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File \"${GROK_WORKSPACE_ROOT}/.grok/hooks/bin/stop-reminder.ps1\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
